{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "moduleResolution": "bundler",
    "module": "esnext",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "jsx": "react",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": "."
  },
  "include": ["*.ts", "*.tsx"]
}
